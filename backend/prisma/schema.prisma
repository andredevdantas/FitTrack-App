generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  password         String?
  googleId         String?  @unique
  isEmailVerified  Boolean  @default(false)
  verificationCode String?
  xp               Int      @default(0)
  totalWorkouts    Int      @default(0)
  totalMissions    Int      @default(0)
  
  // Relacionamentos
  workouts         Workout[]
  streak           Streak?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workout {
  id          String   @id @default(uuid())
  title       String
  durationMin Int      
  xpAwarded   Int
  date        DateTime @default(now())

  // Relacionamento
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Streak {
  id            String   @id @default(uuid())
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActive    DateTime @default(now())

  // Relacionamento
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
}

model Exercise {
  id        String   @id @default(uuid())
  name      String
  details   String
  dayOfWeek String
  createdAt DateTime @default(now())

  @@map("exercises")
}

model DailyMission {
  id          String   @id @default(uuid())
  description String
  xp          Int
  createdAt   DateTime @default(now())

  @@map("daily_missions")
}

model Medal {
  id          String   @id @default(uuid())
  name        String
  description String
  type        String
  requirement Int
  icon        String
  color       String
  createdAt   DateTime @default(now())

  @@map("medals")
}